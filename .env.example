APP_NAME=Vitrine
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://api.vitrine.localhost
APP_TIMEZONE=America/Sao_Paulo
APP_LOCALE=pt_BR

FRONTEND_URL=http://app.vitrine.localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

# PostgreSQL — via container Docker (serviço "postgres")
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=vitrine
DB_USERNAME=vitrine
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=redis
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

# Redis — local (mesmo container ou serviço redis no docker-compose)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Laravel Passport (RS256 via php artisan passport:keys)
# Após gerar, copie o conteúdo das chaves abaixo (ou deixe em storage/)
PASSPORT_PRIVATE_KEY=
PASSPORT_PUBLIC_KEY=

# Google OAuth (Socialite) — console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://api.vitrine.localhost/auth/google/callback

# Meta Pixel ID (apenas referência — usado no frontend)
# META_PIXEL_ID=
